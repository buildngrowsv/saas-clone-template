# =============================================================================
# SaaS Clone Template — Environment Variables
# =============================================================================
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains secrets.
# =============================================================================

# --- App URL ---
# Public site URL used by auth redirects, checkout redirects, and metadata.
# In local development this repo runs on port 4837.
NEXT_PUBLIC_APP_URL=http://localhost:4837

# --- Better Auth (Authentication) ---
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-here
# Legacy fallback only while migrating older deployments. Prefer BETTER_AUTH_SECRET.
NEXTAUTH_SECRET=

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: http://localhost:4837/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Stripe (Payments) ---
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Webhook secret from: stripe listen --forward-to localhost:4837/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Stripe Price IDs (server-side, used by webhook + checkout API routes) ---
# Create products/prices via: npm run stripe:setup
# These are the recurring subscription price IDs the webhook maps to credit grants.
STRIPE_PRICE_BASIC=price_basic_monthly_id
STRIPE_PRICE_PRO=price_pro_monthly_id

# --- Stripe Public Keys (client-side, used by pricing page + checkout redirect) ---
# The publishable key loads Stripe.js in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Subscription tier price IDs shown on the pricing page.
NEXT_PUBLIC_STRIPE_PRICE_BASIC_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_STANDARD_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
# One-time credit pack price IDs.
NEXT_PUBLIC_STRIPE_PRICE_STARTER_PACK=
NEXT_PUBLIC_STRIPE_PRICE_GROWTH_PACK=
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL_PACK=

# --- Google Analytics 4 (optional) ---
# Measurement ID from GA4 Admin → Data streams. Either variable works; if both are set,
# NEXT_PUBLIC_GA_MEASUREMENT_ID takes precedence (legacy clones often use NEXT_PUBLIC_GA_ID).
# When unset, no gtag load and no cookie consent banner (nothing to consent to).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA_ID=

# --- fal.ai (AI Model Inference) ---
# Get key at: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-ai-key

# --- Resend (Welcome Email / Transactional Email) ---
# Holding-company standard: Resend (https://resend.com)
# Account: buildngrowsv@gmail.com
# The welcome email fires on signup via Better Auth databaseHooks.
# When these are not set, welcome emails are silently skipped (signup still works).
RESEND_API_KEY=
# Verified sender — must match a domain verified in Resend dashboard.
# Example: noreply@yourtool.symplyai.io or hello@yourdomain.com
RESEND_FROM_EMAIL=

# --- Support Email (shown on legal pages) ---
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# --- Cloudflare R2 (optional file storage) ---
# Only needed if the product stores user uploads in R2.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# --- Database ---
# PostgreSQL connection string (Neon, Supabase, or local)
# For fleet mode: all clones share one Neon DB, scoped by product_slug
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Fleet Analytics (optional, admin only) ---
# Secret for the /api/fleet-analytics endpoint. When unset, the endpoint returns 404.
# Generate: openssl rand -base64 32
# FLEET_ANALYTICS_SECRET=
