# ==============================================================================
# SaaS Clone Template — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains secrets.
#
# Required services:
# 1. Neon Postgres (https://neon.tech) — serverless database
# 2. Google Cloud Console (https://console.cloud.google.com) — OAuth
# 3. Stripe (https://stripe.com) — payments
# 4. Cloudflare R2 (https://developers.cloudflare.com/r2/) — file storage
# ==============================================================================

# ------------------------------------------------------------------------------
# APP
# The public URL of your app. Used for auth callbacks, SEO, and Stripe redirects.
# In development: http://localhost:4738
# In production: https://yourdomain.com
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:4738

# ------------------------------------------------------------------------------
# DATABASE (Neon Postgres)
# Get this from: https://console.neon.tech → your project → Connection Details
# Use the "Pooled connection" string for serverless deployments.
# Format: postgresql://user:password@host/database?sslmode=require
# ------------------------------------------------------------------------------
DATABASE_URL=

# ------------------------------------------------------------------------------
# AUTHENTICATION (Better Auth + Google OAuth)
#
# BETTER_AUTH_SECRET: A random 32+ character string for signing session tokens.
# Generate one with: openssl rand -base64 32
#
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: Create at Google Cloud Console:
# 1. Go to APIs & Services → Credentials → Create OAuth Client ID
# 2. Application type: Web application
# 3. Authorized redirect URI: http://localhost:4738/api/auth/callback/google
#    (add your production URL too when deploying)
# 4. Copy the Client ID and Client Secret
# ------------------------------------------------------------------------------
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# STRIPE (Payments)
#
# STRIPE_SECRET_KEY: From Stripe Dashboard → Developers → API Keys → Secret key
# Use test key (sk_test_...) for development, live key (sk_live_...) for production.
#
# STRIPE_WEBHOOK_SECRET: From Stripe Dashboard → Developers → Webhooks
# 1. Create endpoint: https://yourdomain.com/api/stripe/webhook
# 2. Select events: checkout.session.completed, customer.subscription.created,
#    customer.subscription.updated, customer.subscription.deleted,
#    invoice.payment_succeeded
# 3. Copy the signing secret (whsec_...)
#
# For local development, use Stripe CLI:
#   stripe listen --forward-to localhost:4738/api/stripe/webhook
#   (copy the whsec_ value it prints)
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# STRIPE PRICE IDS
#
# Create Products and Prices in Stripe Dashboard, then paste the price IDs here.
# Use NEXT_PUBLIC_ prefix because the pricing page (client component) needs them.
# Stripe Price IDs are NOT secrets — the secret is STRIPE_SECRET_KEY.
#
# For subscriptions, add metadata to each Price: { "plan": "basic" }
# For credit packs, add metadata to each Price: { "pack_type": "starter" }
# ------------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PRICE_BASIC_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_STANDARD_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_STARTER_PACK=
NEXT_PUBLIC_STRIPE_PRICE_GROWTH_PACK=
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL_PACK=

# ------------------------------------------------------------------------------
# CLOUDFLARE R2 (File Storage)
#
# Get these from Cloudflare Dashboard → R2 → Manage R2 API Tokens
# 1. Create an API token with read/write permissions for your bucket
# 2. Note your Account ID from the Cloudflare dashboard URL
# 3. Create a bucket and note its name
# 4. (Optional) Set up a custom domain for public access → R2_PUBLIC_URL
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
